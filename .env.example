# LLM provider for the coding agent chat loop.
# Supported: huggingface, groq
LLM_PROVIDER=huggingface
LLM_API_KEY=
LLM_MODEL=Qwen/Qwen3-Coder-30B-A3B-Instruct
LLM_FALLBACK_MODELS=deepseek-ai/DeepSeek-R1-0528,meta-llama/Llama-3.3-70B-Instruct
LLM_BASE_URL=https://router.huggingface.co/v1

# Optional Groq key kept for voice transcription unless/until voice is migrated.
GROQ_API_KEY=

# Telegram — @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=123456789

# GitHub — https://github.com/settings/tokens (fine-grained, repo scope)
GITHUB_TOKEN=
GITHUB_DEFAULT_BRANCH=main

# E2B — https://e2b.dev/dashboard
E2B_API_KEY=

# Hugging Face Hub token for model downloads / embeddings if different from LLM_API_KEY.
HF_TOKEN=

# Runtime
LOG_LEVEL=INFO
CHECKPOINT_DIR=./checkpoints
CHROMA_DIR=./chroma_data
MAX_TEST_RETRIES=3

# LangSmith (optional — enables tracing + Studio replay)
# https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=clawcode
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
