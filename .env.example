# Groq — https://console.groq.com/keys
GROQ_API_KEY=
# Primary model + comma-separated fallback chain. Fallbacks kick in after the
# primary exhausts its retries (e.g. on 429/5xx/model-not-available). Keep
# tool-calling-capable models only — non-tool models will crash the chat node.
GROQ_MODEL=qwen/qwen3-32b
GROQ_FALLBACK_MODELS=openai/gpt-oss-20b,meta-llama/llama-4-scout-17b-16e-instruct

# Telegram — @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=123456789

# GitHub — https://github.com/settings/tokens (fine-grained, repo scope)
GITHUB_TOKEN=
GITHUB_DEFAULT_BRANCH=main

# E2B — https://e2b.dev/dashboard
E2B_API_KEY=

# Hugging Face (optional; authenticates sentence-transformer model downloads)
HF_TOKEN=

# Runtime
LOG_LEVEL=INFO
CHECKPOINT_DIR=./checkpoints
CHROMA_DIR=./chroma_data
MAX_TEST_RETRIES=3

# LangSmith (optional — enables tracing + Studio replay)
# https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=clawcode
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
